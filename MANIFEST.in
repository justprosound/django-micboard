# Include documentation at root level
include README.md
include LICENSE
include CONTRIBUTING.md
include CHANGELOG.md
include pyproject.toml
include .env.example

# Include Django app resources. The wheel validator keeps this list aligned with
# the source tree so new resource types cannot silently disappear from releases.
recursive-include micboard/static *
recursive-include micboard/templates *
recursive-include micboard/migrations *
recursive-include micboard/fixtures *

# Exclude development, test, and cache files
recursive-exclude * __pycache__
recursive-exclude * *.py[co]
recursive-exclude * .DS_Store
recursive-exclude * .git*
exclude .gitignore .pre-commit-config.yaml pytest.ini mkdocs.yml
exclude *.sh
exclude SECURITY.md ARCHITECTURE_*.md *_SUMMARY.md *_TRACKING.md *_WORKSHEET.md IMPLEMENTATION_*.md BREAKING_*.md LINTING_*.md MIGRATION_*.md PERFORMER_*.md REFACTORING_*.md SETTINGS_*.md QUICK_START*.md BATTERY_*.md

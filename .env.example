# Environment consumed by example_project/settings.py.
#
# Copy this file to .env only as a local reference. Django and start-dev.sh do
# not load it implicitly. To use it for one command, run for example:
#   uv run --env-file .env --no-sync python manage.py runserver
#
# Never commit a populated .env file. Production hosts should keep secrets in
# their platform's secret manager and use PostgreSQL; SQLite is for development.

# Django example project
DJANGO_SECRET_KEY=django-insecure-change-me-for-local-development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave unset for the local SQLite database.
# DJANGO_DATABASE_URL=postgresql://user:password@localhost:5432/micboard

# Shure System API values mapped into MICBOARD_CONFIG by the example project
MICBOARD_SHURE_API_BASE_URL=https://localhost:10000
MICBOARD_SHURE_API_SHARED_KEY=replace-with-your-shared-key

# Hostnames that Manufacturer API Server rows may contact
MICBOARD_API_SERVER_ALLOWED_HOSTS=localhost
